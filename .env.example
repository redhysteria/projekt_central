# Ahrefs MCP API Configuration
# Uzyskaj klucz API z: https://ahrefs.com/api
AHREFS_MCP_API_KEY=your_ahrefs_mcp_api_key_here
AHREFS_MCP_ENABLED=True
AHREFS_FALLBACK_TO_MOCK=True
AHREFS_RPM=60

# Jina AI Configuration
# Uzyskaj klucz API z: https://jina.ai
JINA_API_KEY=your_jina_api_key_here
JINA_RPM=100

# OpenAI Configuration
# Uzyskaj klucz API z: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_RPM=500

# Application Settings
DEBUG=False
