# Ahrefs API v3 Configuration
# Uzyskaj klucz API z: https://ahrefs.com/api (wymagany plan Standard)
AHREFS_API_KEY=your_ahrefs_api_key_here
AHREFS_ENABLED=True
AHREFS_FALLBACK_TO_MOCK=False
AHREFS_RPM=60
AHREFS_TIMEOUT=30

# Jina AI Configuration
# Uzyskaj klucz API z: https://jina.ai
JINA_API_KEY=your_jina_api_key_here
JINA_RPM=100

# Gemini API Configuration
# Uzyskaj klucz API z: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_RPM=60

# Senuto API Configuration
# Wygeneruj token przez POST https://api.senuto.com/api/users/token (e-mail + hasło)
# Token jest ważny 30 dni - patrz SENUTO_SETUP.md
SENUTO_API_TOKEN=your_senuto_bearer_token_here
SENUTO_ENABLED=True
SENUTO_COUNTRY_ID=200
SENUTO_FETCH_MODE=topLevelDomain
SENUTO_TOP10_MAX_PAGES=50
SENUTO_TIMEOUT=30

# Application Settings
DEBUG=False
